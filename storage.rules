rules_version = '2';

// AkkerBooster Firebase Storage security rules.
// Paste into Firebase console → Storage → Rules → Publish.
//
// Model: anyone may VIEW images (public read, like the rest of the site), but a
// signed-in user may only write into their OWN folder (uploads/<their-uid>/...),
// and only image files up to 8 MB. This matches how firebase.js builds the path
// in AK.uploadImage().

service firebase.storage {
  match /b/{bucket}/o {

    // All uploaded media lives under a per-folder, per-user path:
    //   <folder>/<uid>/<timestamp>_<name>   e.g. topics/abc123/169..._leaf.jpg
    match /{folder}/{uid}/{fileName} {
      // Public read so photos show for guests, just like topics/replies.
      allow read: if true;

      // Write only as yourself, images only, max 8 MB.
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
